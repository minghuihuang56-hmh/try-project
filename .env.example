# ============================================
# 数据分析 Agent — 环境配置
# ============================================

# DeepSeek API Key（推荐，注册即送额度）
# 注册地址：https://platform.deepseek.com/sign_up
# 配置后自动启用 AI 模式，不配则使用离线规则模式
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# API 地址（通常无需修改）
API_BASE_URL=https://api.deepseek.com

# 模型名称（通常无需修改）
MODEL_NAME=deepseek-v4-pro
